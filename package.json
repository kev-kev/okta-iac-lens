{
  "name": "okta-iac-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first tool that reads Terraform-managed Okta config, visualizes access paths, and measures IaC coverage.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
