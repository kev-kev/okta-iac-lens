{
  "name": "okta-iac-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first tool that reads Terraform-managed Okta config, visualizes access paths, and measures IaC coverage.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "smoke": "tsx scripts/live-smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "web": "vite --config src/render/web/vite.config.ts",
    "web:typecheck": "tsc -p src/render/web/tsconfig.json",
    "web:build": "tsc -p src/render/web/tsconfig.json && vite build --config src/render/web/vite.config.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.11.1",
    "commander": "^15.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
