# Okta Integrator (free) tenant credentials — used by `--source okta` and `npm run smoke`.
#
# Placeholder values ONLY. Real secrets go in `.env` (gitignored), never here.
#
# OKTA_ORG_URL: the org hostname WITHOUT `-admin` (e.g. https://integrator-123.okta.com).
# OKTA_API_TOKEN: an SSWS token minted while signed in as a READ-ONLY ADMINISTRATOR
# user (SSWS tokens inherit their creator's permissions and can't be scope-limited).
# Verify the credential really can't write: npm run smoke -- --verify-readonly

OKTA_ORG_URL=https://your-org.okta.com
OKTA_API_TOKEN=your-read-only-api-token
