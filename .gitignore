# Dependencies & build output
node_modules/
dist/
dist-web/

# Secrets — never commit
.env
.env.*
!.env.example

# Terraform state contains secrets + PII. NEVER commit a real tenant export.
*.tfstate
*.tfstate.json
*.tfstate.backup

# ...but the hand-crafted, FAKE-DATA fixture is committed on purpose.
!fixtures/sample-tenant.tfstate.json

# ...and the SANITIZED real-tenant state (fake ids/secrets, structure preserved 1:1;
# produced by scripts/sanitize-captures.ts from the gitignored raw export). Committed
# on purpose as the M11 Phase C ground-truth fixture. The RAW real-tenant.tfstate.json
# stays ignored by the rule above.
!fixtures/api-real/tenant.tfstate.json

# Generated artifacts (import blocks, exports, etc.)
generated/

# Terraform working-dir artifacts (provider binaries, local state, plan cache)
.terraform/
.terraform.lock.hcl
*.tfplan

# Per-user Claude Code permission grants — machine-local, not shared config
.claude/settings.local.json
